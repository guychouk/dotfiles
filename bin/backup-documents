#!/bin/bash

# Configuration
SOURCE_DIR="$HOME/Documents"
BACKUP_DIR="$HOME/backups"
DATE=$(date +%Y-%m-%d)
BACKUP_TARGET="$BACKUP_DIR/documents-backup-${DATE}"
LOG_FILE="$BACKUP_DIR/backup.log"
RETENTION_DAYS=30

# Create backup directory if it doesn't exist
mkdir -p "$BACKUP_DIR"

# Log start
echo "$(date '+%Y-%m-%d %H:%M:%S') - Starting backup..." >> "$LOG_FILE"

# Create backup using rsync
if rsync -a --delete \
    --no-perms --no-owner --no-group \
    --exclude '.DS_Store' \
    --exclude '*.tmp' \
    --exclude 'Audacity' \
    --exclude 'MPC Beats' \
    --exclude 'TrenchBroom' \
    --exclude 'r2corpus' \
    "$SOURCE_DIR/" "$BACKUP_TARGET/" 2>> "$LOG_FILE"; then

    # Get backup size
    BACKUP_SIZE=$(du -sh "$BACKUP_TARGET" | cut -f1)
    echo "$(date '+%Y-%m-%d %H:%M:%S') - Backup completed: documents-backup-${DATE} ($BACKUP_SIZE)" >> "$LOG_FILE"

    # Delete backups older than retention period
    find "$BACKUP_DIR" -name "documents-backup-*" -type d -mtime +$RETENTION_DAYS -exec rm -rf {} +
    echo "$(date '+%Y-%m-%d %H:%M:%S') - Cleaned up backups older than $RETENTION_DAYS days" >> "$LOG_FILE"
else
    echo "$(date '+%Y-%m-%d %H:%M:%S') - ERROR: Backup failed!" >> "$LOG_FILE"
    exit 1
fi
