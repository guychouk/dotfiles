#!/bin/sh
if [ $# -eq 0 ]; then
  echo "Usage: pr-unresolved <pr-number> [owner/repo]"
  exit 1
fi

pr_number="$1"

if [ $# -ge 2 ]; then
  owner=$(echo "$2" | cut -d/ -f1)
  repo_name=$(echo "$2" | cut -d/ -f2)
else
  remote=$(gh repo view --json nameWithOwner --jq '.nameWithOwner' 2>/dev/null)
  owner=$(echo "$remote" | cut -d/ -f1)
  repo_name=$(echo "$remote" | cut -d/ -f2)
fi

# shellcheck disable=SC2016
gh api graphql -f query="
{
  repository(owner: \"$owner\", name: \"$repo_name\") {
    pullRequest(number: $pr_number) {
      reviewThreads(first: 100) {
        nodes {
          isResolved
          comments(first: 1) {
            nodes { body url }
          }
        }
      }
    }
  }
}" | jq -r '
  .data.repository.pullRequest.reviewThreads.nodes[]
  | select(.isResolved == false)
  | "───────────────────────────────────────────────────────────\n\(.comments.nodes[0].url)\n\n\(.comments.nodes[0].body)\n"
'
