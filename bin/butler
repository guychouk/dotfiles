#!/bin/sh

export PATH="/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin"

action=$(printf 'file\ndirectory\nclipboard\npassword' | $HOME/bin/picker)
case "$action" in
  'file')
    find ~/Documents -type f -not -path '*/.git/*' \
      | $HOME/bin/picker | tr -d '\n' | /usr/bin/pbcopy
    ;;
  'directory')
    find ~/src ~/Documents ~/projects -type d -maxdepth 3 \
      -not -path '*/.git/*' -not -name '.git' \
      | $HOME/bin/picker | tr -d '\n' | /usr/bin/pbcopy
    ;;
  'clipboard')
    $HOME/bin/clippy --list | $HOME/bin/picker | $HOME/bin/clippy --paste
    ;;
  'password')
    prefix="${PASSWORD_STORE_DIR:-$HOME/.password-store}"
    entry=$(find "$prefix" -name '*.gpg' | sed "s|^$prefix/||;s|\.gpg\$||" | $HOME/bin/picker)
    [ -z "$entry" ] && exit 0
    /opt/homebrew/bin/pass show "$entry" | head -1 | $HOME/bin/pbpass
    ;;
esac
