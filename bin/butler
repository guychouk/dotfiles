#!/bin/sh

export PATH="/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin:$HOME/bin"

action=$(printf 'file\ncaffeinate\ndirectory\nclipboard\npassword\nusername' | $HOME/bin/picker)
case "$action" in
  'file')
    find ~/Documents -type f -not -path '*/.git/*' \
      | picker | tr -d '\n' | pbcopy
    ;;
  'directory')
    find ~/src ~/Documents ~/projects -type d -maxdepth 3 \
      -not -path '*/.git/*' -not -name '.git' \
      | picker | tr -d '\n' | pbcopy
    ;;
  'clipboard')
    clippy --list | picker | clippy --paste
    ;;
  'password')
    PASSWORD_STORE_DIR="$HOME/.password-store"
    entry=$(find "$PASSWORD_STORE_DIR" -name '*.gpg' | sed "s|^$PASSWORD_STORE_DIR/||;s|\.gpg\$||" | picker)
    [ -z "$entry" ] && exit 0
    pass show "$entry" | sed -n '1p' | pbpass
    ;;
  'username')
    PASSWORD_STORE_DIR="$HOME/.password-store"
    entry=$(find "$PASSWORD_STORE_DIR" -name '*.gpg' | sed "s|^$PASSWORD_STORE_DIR/||;s|\.gpg\$||" | picker)
    [ -z "$entry" ] && exit 0
    pass show "$entry" | sed -n '2p' | pbpass
    ;;
  'caffeinate')
    toggle-caffeinate
    ;;
esac
