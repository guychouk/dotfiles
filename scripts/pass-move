#!/usr/bin/env python3
"""
pass-move - Utilities for moving passwords between pass and KeePass.

Subcommands:
  kdbx-import  Import a KeePass .kdbx file into pass
  xml-import   Import a KeePass XML export into pass
  kdbx-export  Export the pass store to a .kdbx file

Run `pass-move <subcommand> --help` for usage.
"""

import argparse
import getopt
import getpass
import os
import subprocess
import sys
from pathlib import Path
from xml.etree import ElementTree


STORE = Path.home() / ".password-store"


# ---------------------------------------------------------------------------
# Shared helpers
# ---------------------------------------------------------------------------

def get_recipients():
    gpg_id_file = STORE / ".gpg-id"
    return [line.strip() for line in gpg_id_file.read_text().splitlines() if line.strip()]


def gpg_encrypt_binary(data, dest_path, recipients):
    cmd = ["gpg", "--batch", "--yes", "--output", str(dest_path)]
    for recipient in recipients:
        cmd += ["--recipient", recipient]
    cmd.append("--encrypt")
    proc = subprocess.run(cmd, input=data, capture_output=True)
    return proc.returncode == 0


# ---------------------------------------------------------------------------
# kdbx-import
# ---------------------------------------------------------------------------

def _kdbx_get_password(pass_entry=None):
    if pass_entry:
        result = subprocess.run(["pass", "show", pass_entry], capture_output=True, text=True)
        if result.returncode != 0:
            raise RuntimeError(f"Could not read pass entry '{pass_entry}': {result.stderr.strip()}")
        return result.stdout.splitlines()[0].strip()
    return getpass.getpass("KeePass master password: ")


def _kdbx_entry_group_path(entry):
    parts = []
    group = entry.group
    while group and group.name != "Root":
        parts.insert(0, group.name)
        group = group.parentgroup
    return parts


def _kdbx_build_pass_data(entry):
    lines = [entry.password or ""]
    if entry.username:
        lines.append(f"UserName: {entry.username}")
    if entry.url:
        lines.append(f"URL: {entry.url}")
    if entry.notes:
        lines.append(f"Notes: {entry.notes}")
    if entry.otp:
        lines.append(entry.otp)
    return "\n".join(lines) + "\n"


def _pass_insert(path, data):
    proc = subprocess.run(
        ["pass", "insert", "--multiline", "--force", path],
        input=data.encode("utf-8"),
        capture_output=True,
    )
    return proc.returncode == 0


def cmd_kdbx_import(argv):
    parser = argparse.ArgumentParser(
        prog="pass-move kdbx-import",
        description="Import a KeePass .kdbx file into pass.",
    )
    parser.add_argument("--kdbx", required=True, help="Path to .kdbx file")
    parser.add_argument("--password-entry", help="pass entry containing the kdbx master password")
    args = parser.parse_args(argv)

    try:
        from pykeepass import PyKeePass
    except ImportError:
        print("[ERROR] pykeepass is not installed. Run: pip install pykeepass", file=sys.stderr)
        sys.exit(1)

    password = _kdbx_get_password(args.password_entry)

    try:
        kp = PyKeePass(args.kdbx, password=password)
    except Exception as e:
        print(f"[ERROR] Could not open database: {e}", file=sys.stderr)
        sys.exit(1)

    recipients = get_recipients()
    ok = failed = 0

    for entry in kp.entries:
        if not entry.title:
            continue

        base_parts = _kdbx_entry_group_path(entry) + [entry.title]
        has_attachments = bool(entry.attachments)
        pass_path = "/".join(base_parts + ["password"]) if has_attachments else "/".join(base_parts)

        if _pass_insert(pass_path, _kdbx_build_pass_data(entry)):
            print(f"[OK] {pass_path}")
            ok += 1
        else:
            print(f"[FAIL] {pass_path}")
            failed += 1
            continue

        for attachment in entry.attachments:
            dest = STORE.joinpath(*base_parts) / f"{attachment.filename}.gpg"
            dest.parent.mkdir(parents=True, exist_ok=True)
            if gpg_encrypt_binary(attachment.data, dest, recipients):
                print(f"[OK] {'/'.join(base_parts)}/{attachment.filename}")
                ok += 1
            else:
                print(f"[FAIL] {'/'.join(base_parts)}/{attachment.filename}")
                failed += 1

    print(f"\nDone. {ok} imported, {failed} failed.")


# ---------------------------------------------------------------------------
# xml-import
# ---------------------------------------------------------------------------

def _xml_pass_import_entry(path, data):
    from subprocess import Popen, PIPE
    proc = Popen(["pass", "insert", "--multiline", "--force", path], stdin=PIPE, stdout=PIPE)
    proc.communicate(data.encode("utf8"))
    proc.wait()


def _xml_get_value(elements, node_text):
    for element in elements:
        for child in element.findall("Key"):
            if child.text == node_text:
                return element.find("Value").text
    return ""


def _xml_path_for(element, path=""):
    if element.tag == "Entry":
        title = _xml_get_value(element.findall("String"), "Title")
    elif element.tag == "Group":
        title = element.find("Name").text
    else:
        title = ""
    return title if path == "" else "/".join([path, title])


def _xml_password_data(element, path=""):
    data = ""
    strings = element.findall("String")
    password = _xml_get_value(strings, "Password")
    if password is not None:
        data = password + "\n"
    else:
        print(f"[WARN] No password: {_xml_path_for(element, path)}")

    for field in ["UserName", "URL", "Notes"]:
        value = _xml_get_value(strings, field)
        if value is not None and len(value) > 0:
            data = f"{data}{field}: {value}\n"

    otp = _xml_get_value(strings, "otp")
    if otp and otp.startswith("otpauth://"):
        data = f"{data}{otp}\n"

    return data


def _xml_import_entry(entries, element, path=""):
    element_path = _xml_path_for(element, path)
    if element_path in entries:
        print(f"[INFO] Duplicate needs merging: {element_path}")
        existing_data = entries[element_path]
        data = f"{existing_data}---------\nPassword: {_xml_password_data(element)}"
    else:
        data = _xml_password_data(element, path)
    entries[element_path] = data


def _xml_import_group(entries, element, path="", npath=None):
    if npath is None:
        npath = _xml_path_for(element, path)
    for group in element.findall("Group"):
        _xml_import_group(entries, group, npath)
    for entry in element.findall("Entry"):
        _xml_import_entry(entries, entry, npath)


def cmd_xml_import(argv):
    parser = argparse.ArgumentParser(
        prog="pass-move xml-import",
        description="Import a KeePass XML export into pass.",
    )
    parser.add_argument("-f", "--file", required=True, dest="xml_file", help="Path to KeePass XML export")
    parser.add_argument("-r", "--root", dest="root_path", default=None,
                        help='Root path prefix (use "" for none, defaults to root element name)')
    args = parser.parse_args(argv)

    print(f"[>>>>] Importing passwords from file {args.xml_file}")
    print(f"[INFO] Root path: {args.root_path}")

    entries = {}
    with open(args.xml_file, encoding="utf-8") as xml:
        xml_tree = ElementTree.XML(xml.read())
        root = xml_tree.find("Root")
        root_group = root.find("Group")
        _xml_import_group(entries, root_group, "", args.root_path)

    count = 0
    for path, data in sorted(entries.items()):
        sys.stdout.write(f"[>>>>] Importing {path} ... ")
        sys.stdout.flush()
        _xml_pass_import_entry(path, data)
        sys.stdout.write("OK\n")
        count += 1

    print(f"[ OK ] Done. Imported {count} passwords.")


# ---------------------------------------------------------------------------
# kdbx-export
# ---------------------------------------------------------------------------

def _export_get_master_password(pass_entry):
    result = subprocess.run(["pass", "show", pass_entry], capture_output=True, text=True)
    if result.returncode != 0:
        raise RuntimeError(f"Could not read pass entry '{pass_entry}': {result.stderr.strip()}")
    return result.stdout.splitlines()[0].strip()


def _export_decrypt_entry(rel_path):
    entry_name = str(rel_path).removesuffix(".gpg")
    result = subprocess.run(["pass", "show", entry_name], capture_output=True)
    if result.returncode != 0:
        return None
    try:
        return result.stdout.decode("utf-8")
    except UnicodeDecodeError:
        return None


def _export_parse_entry(content):
    lines = content.splitlines()
    password = lines[0] if lines else ""
    fields = {}
    notes_lines = []
    otp = None
    for line in lines[1:]:
        if line.startswith("otpauth://"):
            otp = line.strip()
        elif ": " in line:
            key, _, value = line.partition(": ")
            fields[key.strip()] = value.strip()
        elif line.strip():
            notes_lines.append(line)
    return password, fields, "\n".join(notes_lines), otp


def _export_get_or_create_group(kp, group_path):
    group = kp.root_group
    for part in group_path:
        existing = kp.find_groups(name=part, group=group, first=True)
        group = existing if existing else kp.add_group(group, part)
    return group


def cmd_kdbx_export(argv):
    default_output = str(Path.home() / "Sync" / "gv-gen.kdbx")
    parser = argparse.ArgumentParser(
        prog="pass-move kdbx-export",
        description="Export the pass store to a KeePass .kdbx file.",
    )
    parser.add_argument("--output", default=default_output, help=f"Output .kdbx path (default: {default_output})")
    parser.add_argument("--password-entry", default="personal/kdbx-master",
                        help="pass entry containing the kdbx master password (default: personal/kdbx-master)")
    args = parser.parse_args(argv)

    try:
        from pykeepass import create_database
    except ImportError:
        print("[ERROR] pykeepass is not installed. Run: pip install pykeepass", file=sys.stderr)
        sys.exit(1)

    skip = {".git", ".DS_Store", ".gpg-id"}
    output = Path(args.output)
    master = _export_get_master_password(args.password_entry)
    kp = create_database(str(output), password=master)

    for gpg_file in sorted(STORE.rglob("*.gpg")):
        rel = gpg_file.relative_to(STORE)
        parts = rel.parts

        if any(p in skip for p in parts):
            continue

        group_parts = list(parts[:-1])
        entry_name = parts[-1].removesuffix(".gpg")

        content = _export_decrypt_entry(rel)
        if content is None:
            print(f"[SKIP] Could not decrypt {rel}")
            continue

        password, fields, notes, otp = _export_parse_entry(content)
        group = _export_get_or_create_group(kp, group_parts)

        entry = kp.add_entry(
            group,
            title=entry_name,
            username=fields.get("UserName", ""),
            password=password,
            url=fields.get("URL", ""),
            notes=notes or fields.get("Notes", ""),
        )
        if otp:
            entry.otp = otp
        print(f"[OK] {rel}")

    kp.save()
    print(f"\nSaved to {output}")


# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

SUBCOMMANDS = {
    "kdbx-import": cmd_kdbx_import,
    "xml-import": cmd_xml_import,
    "kdbx-export": cmd_kdbx_export,
}


def main():
    if len(sys.argv) < 2 or sys.argv[1] not in SUBCOMMANDS:
        print(__doc__)
        print("Available subcommands:", ", ".join(SUBCOMMANDS))
        sys.exit(1 if len(sys.argv) < 2 else 0)

    subcommand = sys.argv[1]
    SUBCOMMANDS[subcommand](sys.argv[2:])


if __name__ == "__main__":
    main()
