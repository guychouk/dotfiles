" Options {{{
set autoindent
set autoread
set backspace=indent,eol,start
set belloff=all
set complete=t,.,w,b,u
set completeopt=menuone
set display=lastline
set encoding=utf-8
set expandtab
set foldlevel=99
set foldmethod=manual
set formatoptions+=j
set history=1000
set ignorecase
set incsearch
set keywordprg=:help
set linebreak
set mouse=a
set nocompatible
set noequalalways
set noerrorbells
set nohlsearch
set noinfercase
set nojoinspaces
set noswapfile
set nrformats=bin,hex
set pumheight=15
set sessionoptions-=options
set shiftround
set shiftwidth=2
set shortmess=aoOstTIc
set sidescroll=1
set sidescrolloff=2
set smartcase
set smarttab
set softtabstop=2
set splitright
set t_vb=
set tabstop=2
set tags=./tags;,tags;
set ttimeout
set ttimeoutlen=100
set undodir=~/.vim/tmp/undo
if !isdirectory(expand(&undodir))
  call mkdir(expand(&undodir), 'p')
endif
set undofile
set undolevels=10000
set updatetime=100
set viewoptions-=options
set wildignore+=**/__pycache__/**,**/.venv/**,**/venv/**
set wildignore+=**/node_modules/**,**/.git/**,**/dist/**,**/build/**,**/vendor/**
set wildignore+=.DS_Store,Icon\?,*.dmg,*.git,*.pyc,*.o,*.obj,*.so,*.swp,*.zip
set wildignorecase
set wildmenu
set wildmode=longest:full,full
set nowrap
set path+=**

if has('clipboard')
  set clipboard^=unnamed,unnamedplus
endif
if has('patch-8.0.1473')
  set shortmess+=F
endif
if has('patch-8.2.4325')
  set wildoptions=pum
endif
if exists('+viminfofile')
  set viminfofile=$XDG_CACHE_HOME/viminfo
endif
if exists('+completepopup')
  set completeopt+=popup
  silent! set completepopup=border:round
  if exists('+pumborder')
    set pumborder=round
  endif
else
  set completeopt+=preview
endif

" Disable netrw before calling filetype
let g:loaded_netrw = 1
let g:loaded_netrwPlugin = 1

filetype plugin indent on
" }}}

" Appearance {{{
syntax enable

set number
set cursorline
set laststatus=2
set signcolumn=yes
set noruler
set noshowcmd
set noshowmode
set notitle
set list
set showbreak=↳
set fillchars=eob:\ 
set listchars=tab:▏\ ,trail:·,extends:>,precedes:<,nbsp:+

if exists('+cursorlineopt')
  set cursorlineopt=number
endif

if has('termguicolors') && $COLORTERM ==# 'truecolor'
  let &t_8f = "\<Esc>[38;2;%lu;%lu;%lum"
  let &t_8b = "\<Esc>[48;2;%lu;%lu;%lum"
  set termguicolors
endif

colorscheme gman
" }}}

