" Dirvish {{{
let g:dirvish_mode = ':sort ,^.*[\/],'
function! s:DirvishEnter() abort
  let l:path = trim(getline('.'))
  if l:path =~? '\.\(png\|jpg\|jpeg\|gif\|bmp\|webp\|tiff\|ico\)$'
    call system('kitty @ launch --type=overlay fish -c ' . shellescape('kitty icat ' . shellescape(l:path) . '; read -n1'))
  else
    if winnr('$') > 1
      wincmd p
      close
    endif
    call dirvish#open('edit', 0)
  endif
endfunction
augroup dirvish_settings
  autocmd!
  autocmd FileType dirvish nnoremap <buffer> <silent> <CR> :call <SID>DirvishEnter()<CR>
  autocmd FileType dirvish nnoremap <buffer> t :call dirvish#open('tabedit', 0)<CR>
  autocmd FileType dirvish xnoremap <buffer> t :call dirvish#open('tabedit', 0)<CR>
augroup END
