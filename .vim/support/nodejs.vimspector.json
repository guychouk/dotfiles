{
  "configurations": {
    "Run": {
      "adapter": "js-debug",
      "configuration": {
        "request": "launch",
        "program": "${workspaceRoot}/web-api.js",
        "cwd": "${workspaceRoot}",
        "console": "intergaredTerminal"
      },
      "breakpoints": {
        "exception": {
          "all": "",
          "uncaught": ""
        }
      }
    },
    "Attach": {
      "adapter": "js-debug",
      "configuration": {
        "type": "pwa-node",
        "request": "attach",
        "skipFiles": ["**/node_modules/**"]
      },
      "breakpoints": {
        "exception": {
          "all": "",
          "uncaught": ""
        }
      }
    }
  }
}
