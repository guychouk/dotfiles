[commit]
	gpgSign = true

[core]
	pager = delta
	quotepath = false

[interactive]
	diffFilter = delta --color-only

[delta]
	dark = true
	navigate = true
	line-numbers = false
	side-by-side = false
	plus-style = "syntax #012800"
	minus-style = "syntax #340001"
	syntax-theme = Monokai Extended

[merge]
	conflictstyle = zdiff3

[init]
	defaultBranch = main

[includeIf "gitdir:/Users/guychouk/projects/"]
	path = ./git-user-personal

[includeIf "gitdir:/Users/guychouk/projects/factify/"]
